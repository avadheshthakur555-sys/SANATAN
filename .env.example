# ─────────────────────────────────────────────────────
# SANATAN App — Environment Variables
# ─────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values.

# ── Required ──────────────────────────────────────────

# SQLite database path (relative to prisma directory)
DATABASE_URL="file:./dev.db"

# ── Optional ──────────────────────────────────────────

# OpenAI API Key — Powers the AI Guru RAG Oracle
# Without this, the Guru falls back to deterministic scriptural synthesis.
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-..."

# Public site URL — Used for sitemap generation and Open Graph tags
# NEXT_PUBLIC_SITE_URL="https://sanatan-katha.org"
